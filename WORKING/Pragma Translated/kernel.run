function outb(int port, int val) returns void
end function

function inb(int port) returns int
  int r
  return r
end function

function ioWait(void _) returns void
  outb(0x80, 0)
end function

type IdtEntry
  int offsetLow
  int selector
  int ist
  int typeAttr
  int offsetMid
  int offsetHigh
  int zero
end type

type IdtPtr
  int limit
  int base
end type

array IdtEntry[256] idt
IdtPtr idtPtr
function picRemap(void _) returns void
  outb(0x20u, 0x11)
  ioWait()
  outb(0xA0u, 0x11)
  ioWait()
  outb(0x21u, 0x20)
  ioWait()
  outb(0xA1u, 0x28)
  ioWait()
  outb(0x21u, 4)
  ioWait()
  outb(0xA1u, 2)
  ioWait()
  outb(0x21u, 0x01)
  ioWait()
  outb(0xA1u, 0x01)
  ioWait()
  outb(0x21u, 0xFD)
  outb(0xA1u, 0xFF)
end function

function picEOI(void _) returns void
  outb(0x20u, 0x20u)
end function

function setIdtGate(int vec, int handler, int sel, int attr) returns void
  idt[vec].offsetLow = change(handler & 0xFFFF)->int
  idt[vec].selector = sel
  idt[vec].ist = 0
  idt[vec].typeAttr = attr
  idt[vec].offsetMid = change((handler right 16) & 0xFFFF)->int
  idt[vec].offsetHigh = change(handler right 32)->int
  idt[vec].zero = 0
end function

function loadIdt(void _) returns void
  idtPtr.limit = change(size(idt) - 1)->int
  idtPtr.base = change(change(address(idt[0]))->uintptr_t)->int
end function

