function putChar(int x, int y, char ch, int fg, int bg) returns void
  if (change(ch)->char < 32) or (change(ch)->char > 126)
    return
  end if
  int idx = (change(ch)->char - 32) * 16
  for int row = 0 while row < 16 do row++
    int bits = font8x16[idx + row]
    for int col = 0 while col < 8 do col++
      int bit = (bits right (7 - col)) & 1
      putPixel(x + col, y + row, /* bit ? fg : bg */)
    end for
  end for
end function

function writeString(int x, int y, string s, int fg, int bg) returns void
  int cx = x
  for int i = 0 while s[i] != 0 do i++
    putChar(cx, y, s[i], fg, bg)
    cx += 8
  end for
end function

function cmdLs(string path) returns void
  DiskFSListResult list_v = DiskFSListRoot()
  chararray_32 sizeBuf
  if list_v.count == 0
    writeString(20, curY, "(disk not ready)", 0xFF888888u, 0xFF001030u)
    curY += 16
    return
  end if
  for int idx = 0 while idx < list_v.count do idx++
    FSObject <ep> = address(list_v.entries[idx])
    writeString(20, curY, ep.Name, 0xFFFFFFFFu, 0xFF001030u)
    formatSize(change(ep.Size)->int, sizeBuf)
    int color = /* ep.FSType == FS_FILE ? 0xFF88FF88u : 0xFF88CCFFu */
    writeString(20 + (20 * 8), curY, sizeBuf, color, 0xFF001030u)
    curY += 16
  end for
end function

function keyboardHandler(void _) returns void
  int sc = inb(0x60)
  if sc & 0x80
    picEOI()
    return
  end if
  char ch = scancodeMap[sc]
  switch ch
  when 0
  when 8
    if curX > (20 + (7 * 8))
      curX -= 8
      putChar(curX, curY, 32, 0xFF001030u, 0xFF001030u)
      if inputLen > 0
        inputLen--
      end if
    end if
  when 10
    inputBuf[inputLen] = 0
    curY += 16
    curX = 20
    if ((inputLen == 2) and (inputBuf[0] == 108)) and (inputBuf[1] == 115)
      cmdLs("/")
    end if
    inputLen = 0
    writeString(curX, curY, "ready> ", 0xFFFFFFFFu, 0xFF001030u)
    curX = 20 + (7 * 8)
  default
    if inputLen < 127
      inputBuf[inputLen] = ch
      inputLen++
    end if
    putChar(curX, curY, ch, 0xFFFFFFFFu, 0xFF001030u)
    curX += 8
  end switch
  picEOI()
end function

function initInterrupts(void _) returns void
  picRemap()
  setIdtGate(33, change(change(keyboard_isr_stub)->uintptr_t)->int, 0x28, 0x8E)
  loadIdt()
end function

function malloc(int size_v) returns none
  return change(0)->none
end function

function free(none p) returns void
end function

function realloc(none p, int size_v) returns none
  return change(0)->none
end function

function calloc(int n, int sz) returns none
  return change(0)->none
end function

function targetA(void _) returns void
  if !initFramebuffer()
    panic("No framebuffer")
  end if
  clearScreen(0xFF001030u)
  writeString(20, 20, "pragma os", 0xFF00FF00u, 0xFF001030u)
  writeString(20, 60, "ready> ", 0xFFFFFFFFu, 0xFF001030u)
  DiskFSInit()
  FSInit()
  initInterrupts()
  while 1 do
  end do
end function

int _binary_logo_bin_start
int _binary_logo_bin_end
function blitBackground(void _) returns void
  int <logoData> = change(address(_binary_logo_bin_start))-><int>
  int w = /* change(fb.width)->int < 1280 ? change(fb.width)->int : 1280 */
  int h = /* change(fb.height)->int < 800 ? change(fb.height)->int : 800 */
  for int y = 0 while y < h do y++
    for int x = 0 while x < w do x++
      putPixel(x, y, logoData[(y * 1280) + x])
    end for
  end for
  for int y = h while y < change(fb.height)->int do y++
    for int x = 0 while x < change(fb.width)->int do x++
      putPixel(x, y, 0xFF001030u)
    end for
  end for
  for int y = 0 while y < h do y++
    for int x = w while x < change(fb.width)->int do x++
      putPixel(x, y, 0xFF001030u)
    end for
  end for
end function

function targetB(void _) returns void
  if !initFramebuffer()
    panic("No framebuffer")
  end if
  blitBackground()
  while 1 do
  end do
end function

function kmain(void _) returns void
  debugPrint("kmain started")
  if bootloaderInfoRequest.response == change(0)->none
    debugPrint("ERROR: bootloader info request failed")
    while 1 do
    end do
  end if
  debugPrint("bootloader info OK")
  if framebufferRequest.response == change(0)->none
    debugPrint("ERROR: framebuffer request failed")
    while 1 do
    end do
  end if
  debugPrint("framebuffer request OK")
  targetA()
end function
