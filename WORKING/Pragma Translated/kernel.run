constant int MemFSFile = 0
constant int MemFSDir = 1

type MemFSObject
  chararray_32 name
  int ftype
  int size
end type

type MemFSDirSlot
  chararray_32 path
  array[MemFSObject][16] entries
  int count
  int used
end type

array MemFSDirSlot[8] FSDirectoryTable
function strToName(chararray_32 dst, string src) returns void
  int i = 0
  while (src[i] != 0) and (i < (32 - 1)) do
    dst[i] = src[i]
    i++
  end do
  dst[i] = 0
end function

function strToPath(chararray_32 dst, string src) returns void
  int i = 0
  while (src[i] != 0) and (i < (32 - 1)) do
    dst[i] = src[i]
    i++
  end do
  dst[i] = 0
end function

function nameEq(string a, string b) returns int
  int i = 0
  while b[i] != 0 do
    if a[i] != b[i]
      return 0
    end if
    i++
  end do
  return a[i] == 0
end function

function FSList(string path) returns <MemFSDirSlot>
  for int i = 0 while i < 8 do i++
    if FSDirectoryTable[i].used and nameEq(FSDirectoryTable[i].path, path)
      return address(FSDirectoryTable[i])
    end if
  end for
  return change(0)->none
end function

function FSInit(void _) returns void
  for int i = 0 while i < 8 do i++
    FSDirectoryTable[i].used = 0
    FSDirectoryTable[i].count = 0
  end for
  strToPath(FSDirectoryTable[0].path, "/")
  FSDirectoryTable[0].used = 1
  FSDirectoryTable[0].count = 2
  strToName(FSDirectoryTable[0].entries[0].name, "docs")
  FSDirectoryTable[0].entries[0].ftype = MemFSDir
  FSDirectoryTable[0].entries[0].size = 0
  strToName(FSDirectoryTable[0].entries[1].name, "readme.txt")
  FSDirectoryTable[0].entries[1].ftype = MemFSFile
  FSDirectoryTable[0].entries[1].size = 1234
end function

constant int fsuB = 0
constant int fsuKB = 1
constant int fsuMB = 2
constant int fsuGB = 3

function intToStr(int v, chararray_32 buf, int start) returns int
  if v == 0
    buf[start] = 48
    return start + 1
  end if
  chararray_16 tmp
  int len = 0
  while (v > 0) and (len < 16) do
    tmp[len++] = 48 + (v % 10)
    v /= 10
  end do
  int pos = start
  for int i = len - 1 while i >= 0 do i--
    buf[pos++] = tmp[i]
  end for
  return pos
end function

function appendCStr(chararray_32 buf, int pos, string s) returns int
  int i = 0
  while (s[i] != 0) and (pos < 31) do
    buf[pos++] = s[i++]
  end do
  buf[pos] = 0
  return pos
end function

function formatSize(int size_v, chararray_32 buf) returns void
  int KB = 1000
  int MB = 1000000
  int GB = 1000000000
  int n
  int unit
  if size_v >= GB
    n = size_v / GB
    unit = fsuGB
  else if size_v >= MB
    n = size_v / MB
    unit = fsuMB
  else if size_v >= KB
    n = size_v / KB
    unit = fsuKB
  else
    n = size_v
    unit = fsuB
  end if
  if (unit == fsuB) and (n >= 1000)
    n /= KB
    unit = fsuKB
  else if (unit == fsuKB) and (n >= 1000)
    n /= KB
    unit = fsuMB
  else if (unit == fsuMB) and (n >= 1000)
    n /= KB
    unit = fsuGB
  end if
  int p = intToStr(n, buf, 0)
  string unitStr
  switch unit
  when fsuB
    unitStr = " B"
  when fsuKB
    unitStr = " KB"
  when fsuMB
    unitStr = " MB"
  default
    unitStr = " GB"
  end switch
  appendCStr(buf, p, unitStr)
end function

function serialWrite(char c) returns void
end function

function debugPrint(string s) returns void
  for int i = 0 while s[i] != 0 do i++
    serialWrite(s[i])
  end for
  serialWrite(10)
end function

function debugHex(int val) returns void
  chararray_256 hexChars
  for int i = 15 while i >= 0 do i--
    int nibble = (val right (i * 4)) & 0xF
    serialWrite(hexChars[nibble])
  end for
  serialWrite(10)
end function

function panic(string msg) returns void
  while 1 do
  end do
end function

LimineFramebuffer <fb> = change(0)->none
function initFramebuffer(void _) returns int
  if framebufferRequest.response == change(0)->none
    return 0
  end if
  if framebufferRequest.response.framebufferCount == 0
    return 0
  end if
  fb = deref(framebufferRequest.response.framebuffers)
  return 1
end function

function putPixel(int x, int y, int color) returns void
  if fb == change(0)->none
    return
  end if
  if (x < 0) or (y < 0)
    return
  end if
  if (x >= change(fb.width)->int) or (y >= change(fb.height)->int)
    return
  end if
  int offset = (y * change(fb.pitch)->int) + (x * 4)
  int <pixel> = change(change(fb.address)->uintptr_t + change(offset)->uintptr_t)-><int>
  deref(<pixel>) = color
end function

function clearScreen(int color) returns void
  if fb == change(0)->none
    return
  end if
  for int y = 0 while y < change(fb.height)->int do y++
    for int x = 0 while x < change(fb.width)->int do x++
      putPixel(x, y, color)
    end for
  end for
end function

